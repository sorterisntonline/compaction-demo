# OpenRouter API Key for LLM models
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default model used by the being
ADAM_MODEL=anthropic/claude-3.5-sonnet

# Default vote model used for memory curation (subconscious voting)
ADAM_VOTE_MODEL=google/gemini-2.5-flash

# Default memory capacity before compaction occurs
ADAM_CAPACITY=100

